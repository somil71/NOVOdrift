# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server-only, never expose

# ── Site (required in production) ──
NEXT_PUBLIC_SITE_URL=https://fitboard.vercel.app   # drives CORS + OG tags

# ── Admin allowlist (recommended in production) ──
# Comma-separated emails allowed into /admin and content-write APIs.
# If empty, ANY authenticated user is treated as admin (dev convenience).
ADMIN_EMAILS=you@example.com

# ── Upstash Redis (optional) ──
# If set, /api/track/r uses distributed rate limiting; otherwise in-memory fallback.
# Add via Vercel → Storage → Upstash (auto-injects these two).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Monitoring ──
# Vercel Analytics & Speed Insights need NO keys — enable them in the Vercel dashboard.
